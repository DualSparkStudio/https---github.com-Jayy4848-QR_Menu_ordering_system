# Supabase PostgreSQL Connection Strings
# Get these from: Supabase Dashboard > Project Settings > Database

# Pooled connection (for serverless queries) - use Transaction mode
# IMPORTANT: Set connection_limit=10 (NOT 1) for better performance
DATABASE_URL="postgresql://postgres.chnzfuzczkoaginjfwzi:cafeqrsyste@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10"

# Direct connection (for migrations) - use Session mode
DIRECT_URL="postgresql://postgres.chnzfuzczkoaginjfwzi:cafeqrsyste@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

# JWT Secret (generate a random string)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Push Notifications (REQUIRED for notifications to work)
# Generate VAPID keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@cafeqrsystem.com"
